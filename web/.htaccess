# index.htmlはキャッシュしない（JS/CSSはバージョンパラメータで管理）
<filesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires 0
</filesMatch>

# data/ディレクトリへの直接アクセスを禁止（api/data.php経由のみ許可）
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^data/ - [F,L]
</IfModule>

# config.phpへの直接アクセスを禁止（パスワードハッシュ保護）
<filesMatch "config\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</filesMatch>

# api/内のJSONデータファイルへの直接アクセスを禁止
# board_data.json, counter_data.json, counter_total.json がサーバーで自動生成される
<filesMatch "(board_data|counter_data|counter_total)\.json$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</filesMatch>

# JSONファイルのキャッシュ制御
<filesMatch "\.json$">
  Header set Cache-Control "private, no-store"
</filesMatch>

# DB・スキーマファイルへの直接アクセスを禁止
<filesMatch "\.(sqlite|sqlite3|db|sql)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</filesMatch>

# セキュリティヘッダー
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>
