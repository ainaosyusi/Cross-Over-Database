#!/bin/bash
# === pre-commit フック（個人情報・機密ファイル保護）===

STAGED=$(git diff --cached --name-only)
BLOCKED=""

# --- 1. 一般的な機密ファイルパターン ---
SENSITIVE_PATTERNS=(
  "\.env$"
  "\.env\."
  "credentials"
  "secret"
  "\.pem$"
  "\.key$"
  "id_rsa"
)

for pattern in "${SENSITIVE_PATTERNS[@]}"; do
  match=$(echo "$STAGED" | grep -iE "$pattern")
  if [ -n "$match" ]; then
    BLOCKED="${BLOCKED}\n  - ${match}"
  fi
done

# --- 2. プロジェクト固有ブロックリスト ---
BLOCKLIST=".git-blocked-files"
if [ -f "$BLOCKLIST" ]; then
  while IFS= read -r line; do
    [[ "$line" =~ ^#.*$ || -z "$line" ]] && continue
    match=$(echo "$STAGED" | grep "^${line}")
    if [ -n "$match" ]; then
      BLOCKED="${BLOCKED}\n  - ${match}"
    fi
  done < "$BLOCKLIST"
fi

# --- 3. グローバルフックがあれば実行 ---
GLOBAL_HOOK="$HOME/.githooks/pre-commit"
if [ -x "$GLOBAL_HOOK" ] && [ "$(realpath "$0")" != "$(realpath "$GLOBAL_HOOK")" ]; then
  "$GLOBAL_HOOK"
  if [ $? -ne 0 ]; then
    exit 1
  fi
fi

if [ -n "$BLOCKED" ]; then
  echo ""
  echo "============================================"
  echo "  BLOCKED: 機密/個人情報ファイルを検出"
  echo "============================================"
  echo -e "以下のファイルはコミットできません:${BLOCKED}"
  echo ""
  echo "誤検知の場合: git commit --no-verify"
  echo "============================================"
  exit 1
fi
